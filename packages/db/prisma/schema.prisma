// Pirate-Battle database schema.

generator client {
  provider = "prisma-client-js"
  output   = "../generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum BattleMode {
  PVE
  PVP
  AI
}

model User {
  id            String   @id @default(cuid())
  stakeAddr     String?  @unique
  discordUserId String?  @unique
  createdAt     DateTime @default(now())

  captains      Captain[]
  items         Item[]
  battlesAsA    Battle[]       @relation("BattleParticipantA")
  battlesAsB    Battle[]       @relation("BattleParticipantB")
  nftSnapshots  NftSnapshot[]
  pvpChallenges PvpChallenge[]
  pvpQueueEntry PvpQueueEntry?
  pvpRatings    PvpRating[]
}

model NftSnapshot {
  id        String   @id @default(cuid())
  userId    String
  fetchedAt DateTime @default(now())
  nftsJson  Json

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, fetchedAt])
}

model Collection {
  id        String   @id @default(cuid())
  policyId  String   @unique
  name      String
  ruleJson  Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Captain {
  id        String   @id @default(cuid())
  userId    String
  name      String
  factionId String
  createdAt DateTime @default(now())

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  crews Crew[]

  @@index([userId])
}

model Crew {
  id          String   @id @default(cuid())
  captainId   String
  templateKey String
  level       Int      @default(1)
  xp          Int      @default(0)
  attrs       Json     @default("{}")
  createdAt   DateTime @default(now())

  captain Captain    @relation(fields: [captainId], references: [id], onDelete: Cascade)
  moves   CrewMove[]

  @@index([captainId])
}

model CrewMove {
  id        String  @id @default(cuid())
  crewId    String
  moveKey   String
  slot      Int
  isLearned Boolean @default(true)

  crew Crew @relation(fields: [crewId], references: [id], onDelete: Cascade)

  @@unique([crewId, slot])
  @@index([crewId])
}

model Item {
  id          String @id @default(cuid())
  ownerUserId String
  templateKey String
  qty         Int    @default(0)

  owner User @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)

  @@unique([ownerUserId, templateKey])
  @@index([ownerUserId])
}

model Battle {
  id                   String     @id @default(cuid())
  mode                 BattleMode
  participantAId       String
  participantBId       String?
  captainId            String?
  captainBId           String?
  resultJson           Json?
  pendingActionA       Json?
  pendingActionB       Json?
  pendingSubmitAt      DateTime?
  discordChannelId     String?
  discordMessageId     String?
  discordGuildId       String?
  discordMessageSentAt DateTime?
  seed                 Bytes
  startedAt            DateTime   @default(now())
  endedAt              DateTime?

  participantA User          @relation("BattleParticipantA", fields: [participantAId], references: [id], onDelete: Cascade)
  participantB User?         @relation("BattleParticipantB", fields: [participantBId], references: [id], onDelete: SetNull)
  events       BattleEvent[]

  @@index([participantAId])
  @@index([participantBId])
  @@index([endedAt, discordMessageId])
}

model BattleEvent {
  id          String @id @default(cuid())
  battleId    String
  idx         Int
  kindStr     String
  payloadJson Json

  battle Battle @relation(fields: [battleId], references: [id], onDelete: Cascade)

  @@unique([battleId, idx])
}

model PvpChallenge {
  id                  String    @id @default(cuid())
  token               String    @unique
  challengerUserId    String
  challengerCaptainId String
  expiresAt           DateTime
  acceptedBattleId    String?
  acceptedAt          DateTime?
  createdAt           DateTime  @default(now())

  challenger User @relation(fields: [challengerUserId], references: [id], onDelete: Cascade)

  @@index([challengerUserId])
  @@index([expiresAt])
}

model PvpQueueEntry {
  id              String   @id @default(cuid())
  userId          String   @unique
  captainId       String
  matchedBattleId String?
  joinedAt        DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([joinedAt])
}

model Season {
  id        String   @id @default(cuid())
  name      String   @unique
  startsAt  DateTime
  endsAt    DateTime
  createdAt DateTime @default(now())

  ratings PvpRating[]

  @@index([startsAt, endsAt])
}

model PvpRating {
  id        String   @id @default(cuid())
  userId    String
  seasonId  String
  elo       Int      @default(1000)
  wins      Int      @default(0)
  losses    Int      @default(0)
  updatedAt DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  season Season @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  @@unique([userId, seasonId])
  @@index([seasonId, elo])
}

// Pirate-Battle database schema.

generator client {
  provider = "prisma-client-js"
  output   = "../generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum BattleMode {
  PVE
  PVP
  AI
}

model User {
  id        String   @id @default(cuid())
  stakeAddr String?  @unique
  createdAt DateTime @default(now())

  captains       Captain[]
  items          Item[]
  battlesAsA     Battle[]  @relation("BattleParticipantA")
  battlesAsB     Battle[]  @relation("BattleParticipantB")
  nftSnapshots   NftSnapshot[]
}

model NftSnapshot {
  id        String   @id @default(cuid())
  userId    String
  fetchedAt DateTime @default(now())
  nftsJson  Json

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, fetchedAt])
}

model Captain {
  id        String   @id @default(cuid())
  userId    String
  name      String
  factionId String
  createdAt DateTime @default(now())

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  crews Crew[]

  @@index([userId])
}

model Crew {
  id          String   @id @default(cuid())
  captainId   String
  templateKey String
  level       Int      @default(1)
  xp          Int      @default(0)
  attrs       Json     @default("{}")
  createdAt   DateTime @default(now())

  captain Captain    @relation(fields: [captainId], references: [id], onDelete: Cascade)
  moves   CrewMove[]

  @@index([captainId])
}

model CrewMove {
  id        String  @id @default(cuid())
  crewId    String
  moveKey   String
  slot      Int
  isLearned Boolean @default(true)

  crew Crew @relation(fields: [crewId], references: [id], onDelete: Cascade)

  @@unique([crewId, slot])
  @@index([crewId])
}

model Item {
  id          String @id @default(cuid())
  ownerUserId String
  templateKey String
  qty         Int    @default(0)

  owner User @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)

  @@unique([ownerUserId, templateKey])
  @@index([ownerUserId])
}

model Battle {
  id             String     @id @default(cuid())
  mode           BattleMode
  participantAId String
  participantBId String?
  resultJson     Json?
  seed           Bytes
  startedAt      DateTime   @default(now())
  endedAt        DateTime?

  participantA User          @relation("BattleParticipantA", fields: [participantAId], references: [id], onDelete: Cascade)
  participantB User?         @relation("BattleParticipantB", fields: [participantBId], references: [id], onDelete: SetNull)
  events       BattleEvent[]

  @@index([participantAId])
  @@index([participantBId])
}

model BattleEvent {
  id          String @id @default(cuid())
  battleId    String
  idx         Int
  kindStr     String
  payloadJson Json

  battle Battle @relation(fields: [battleId], references: [id], onDelete: Cascade)

  @@unique([battleId, idx])
}

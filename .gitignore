# Environment & secrets
.env
.env.local
.env.*.local

# Build outputs
dist/
dist-types/
dist-types-node/
build/
out/
.next/
.nuxt/
target/
*.tsbuildinfo

# Prisma — generated client; regenerated on `prisma generate`
packages/db/generated/

# Vite
.vite/
*.pyc
__pycache__/
.pytest_cache/

# Dependencies
node_modules/
vendor/
.venv/
venv/

# IDE
.vscode/
.idea/
*.swp

# OS
.DS_Store
Thumbs.db

# Claude Code state
.claude/.setup-progress
# Per-machine Bash permission allow-list — interactive sessions mutate it.
.claude/settings.local.json
# Hook-written observability logs (InstructionsLoaded, etc.) — grow
# unbounded and contain absolute paths specific to the machine.
.claude/logs/

# Approvals (history.md, PENDING.md, and archived approvals) ARE committed
# per the branch-as-payload / auditable-approvals design.

# Deploy artifacts (transient, local only)
scripts/.deploy-lock
scripts/.previous-image

# Capacitor / Android — generated by Gradle, never committed.
# (Capacitor also writes its own android/.gitignore covering cap sync outputs
# like app/src/main/assets/public/. iOS is intentionally out of scope.)
apps/mobile/android/build/
apps/mobile/android/.gradle/
apps/mobile/android/app/build/
apps/mobile/android/local.properties

# Environment variables template — Pirate-Battle.
# Copy to .env (gitignored) on the host machine and fill in real values.
#
# DO NOT commit .env. This .example file is safe to commit.

# --- Claude / Anthropic ---
# Required if Claude Code runs on the VPS and makes API calls directly.
ANTHROPIC_API_KEY=

# --- GitHub (for the autonomous agent) ---
# gh CLI uses its own auth (~/.config/gh/) by default; set this only if you
# want the agent to use a specific token different from `gh auth`.
GITHUB_TOKEN=

# --- App port (Fastify server; nginx proxies pirate-battle.blacksail.dev → here) ---
APP_PORT=3001

# --- Database (Postgres in docker/docker-compose.yml) ---
POSTGRES_USER=app
POSTGRES_PASSWORD=change-me-in-prod
POSTGRES_DB=pirate_battle
# DATABASE_URL is what Prisma reads. Inside docker compose the host is `db`;
# in local dev (Postgres on 5432 of the host machine) it's `localhost`.
DATABASE_URL=postgresql://app:change-me-in-prod@db:5432/pirate_battle

# --- Cardano / Blockfrost ---
# One project_id per network — get from blockfrost.io.
# In dev / preprod testing use the preprod key, NOT mainnet.
BLOCKFROST_NETWORK=preprod
BLOCKFROST_PROJECT_ID=
# Comma-separated allow-list of policy IDs (28-byte / 56-hex-char strings).
# Leave empty to disable NFT-gated content (free starter set still works).
NFT_ALLOWLIST_POLICY_IDS=

# --- Discord bot ---
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
# Optional: scope slash commands to a single guild for instant registration
# in dev. Leave empty in prod for global commands.
DISCORD_DEV_GUILD_ID=

# --- Auth / sessions ---
# 32+ bytes, base64 or hex. Used to sign session cookies / JWTs.
SESSION_SECRET=

# --- autodev-mcp (optional — only if project is on the VPS hosting autodev-mcp) ---
# Heartbeat target so the dashboard at dashboard.blacksail.dev sees the project.
# Same bearer token as the autodev-mcp's BEARER_TOKEN env var.
MCP_HTTP_URL=http://127.0.0.1:4000
MCP_BEARER_TOKEN=

# --- Push notifications (ntfy.sh) ---
# Per-project topic for push notifications from the autonomous-run cycle
# (scripts/notify-cycle.sh pushes here). Sufficiently-random slug essential
# since ntfy topics are public-by-URL.
# Format: pirate-battle-agent-<16 hex chars>
NTFY_TOPIC=
NTFY_SERVER=https://ntfy.sh

# --- Optional: app-feature flags ---
# FEATURE_ASYNC_PVP=false
# FEATURE_DISCORD_BOT=false
